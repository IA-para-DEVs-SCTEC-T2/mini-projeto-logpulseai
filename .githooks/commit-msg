#!/bin/bash

# Git Hook para validar mensagens de commit localmente
# Este script é executado ANTES do commit ser criado

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Define os prefixos permitidos
ALLOWED_PREFIXES="feat|fix|docs|refactor"

# Valida se o commit segue o padrão: <tipo>: <descrição>
# ou <tipo>(escopo): <descrição>
if ! echo "$COMMIT_MSG" | grep -qE "^($ALLOWED_PREFIXES)(\(.+\))?: .+"; then
    echo ""
    echo "❌ ERRO: Mensagem de commit inválida!"
    echo ""
    echo "Mensagem atual: $COMMIT_MSG"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "📋 PADRÃO ACEITO:"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  <tipo>: <descrição curta no imperativo>"
    echo "  <tipo>(escopo): <descrição curta no imperativo>"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "✅ TIPOS PERMITIDOS:"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  • feat:     Nova funcionalidade"
    echo "  • fix:      Correção de bug"
    echo "  • docs:     Documentação"
    echo "  • refactor: Melhoria sem mudar função"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "📝 EXEMPLOS VÁLIDOS:"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  ✅ feat: adiciona parser de logs JSON"
    echo "  ✅ fix: corrige timeout na análise"
    echo "  ✅ docs: atualiza README com exemplos"
    echo "  ✅ refactor: simplifica lógica do analyzer"
    echo "  ✅ feat(cli): adiciona comando analyze"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "💡 COMO CORRIGIR:"
    echo ""
    echo "  Opção 1: Refazer o commit com mensagem correta"
    echo "  git commit -m \"feat: sua descrição aqui\""
    echo ""
    echo "  Opção 2: Corrigir o último commit"
    echo "  git commit --amend -m \"feat: sua descrição aqui\""
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    exit 1
fi

echo "✅ Mensagem de commit válida!"
exit 0
